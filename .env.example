# Bot Token từ @BotFather
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff

# Chuỗi bảo mật cho session (tùy ý)
SESSION_SECRET=your_random_secret_here

# ID nhóm admin chính (bắt đầu bằng -100)
ADMIN_GROUP_ID=-1001234567890

# ID nhóm nhận thông báo rút tiền (nếu khác admin group)
WITHDRAW_GROUP_ID=-1001234567890

# Port API server (nếu chạy riêng)
PORT=8080

# Domain Replit (tự động trên Replit, hoặc set thủ công)
REPLIT_DOMAINS=bot-name.replit.dev